                        "name": "${loki_datasource}"
                      },
                      "spec": {
                        "expr": "sum by (level) (count_over_time({job=~\"integrations/(node_exporter|unix)\",cluster=~\"$cluster\",job=~\"$job\",instance=~\"$instance\",transport=~\"$transport\",unit=~\"$unit\",level=~\"$level\"}\n|~ \"$regex_search\"\n\n[$__auto]))\n",
                        "legendFormat": "{{ level }}"
                      }
                    },
                    "refId": "A",
                    "hidden": false
                  }
                }
              ],
              "transformations": [
                {
                  "kind": "Transformation",
                  "group": "renameByRegex",
                  "spec": {
                    "options": {
                      "regex": "Value",
                      "renamePattern": "logs"
                    }
                  }
                }
              ],
              "queryOptions": {
                "maxDataPoints": 100
              }
            }
          },
          "vizConfig": {
            "kind": "VizConfig",
            "group": "timeseries",
            "version": "v11.0.0",
            "spec": {
              "options": {
                "tooltip": {
                  "mode": "multi",
                  "sort": "desc"
                }
              },
              "fieldConfig": {
                "defaults": {
                  "unit": "none",
                  "custom": {
                    "drawStyle": "bars",
                    "fillOpacity": 50,
                    "stacking": {
                      "mode": "normal"
                    }
                  }
                },
                "overrides": [
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "(E|e)merg|(F|f)atal|(A|a)lert|(C|c)rit.*"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "purple",
                          "mode": "fixed"
                        }
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "(E|e)(rr.*|RR.*)"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "red",
                          "mode": "fixed"
                        }
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "(W|w)(arn.*|ARN.*|rn|RN)"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "orange",
                          "mode": "fixed"
                        }
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "(N|n)(otice|ote)|(I|i)(nf.*|NF.*)"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "green",
                          "mode": "fixed"
                        }
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "dbg.*|DBG.*|(D|d)(EBUG|ebug)"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "blue",
                          "mode": "fixed"
                        }
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "(T|t)(race|RACE)"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "light-blue",
                          "mode": "fixed"
                        }
                      }
                    ]
                  },
                  {
                    "matcher": {
                      "id": "byRegexp",
                      "options": "logs"
                    },
                    "properties": [
                      {
                        "id": "color",
                        "value": {
                          "fixedColor": "text",
                          "mode": "fixed"
                        }
                      }
                    ]
                  }
                ]
              }
            }
          }
        }
